# ─────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ─────────────────────────────────────────────────────
# IMAGE GENERATION
# ─────────────────────────────────────────────────────
# Pollinations.ai is used by default — NO KEY NEEDED.
# To enable HuggingFace (higher quality + inpainting AI):
#   1. Create free account at https://huggingface.co
#   2. Go to https://huggingface.co/settings/tokens
#   3. Create a token (Read access is enough)
#   4. Paste it below

HF_TOKEN=

# ─────────────────────────────────────────────────────
# VIRTUAL TRY-ON MODE
# ─────────────────────────────────────────────────────
# If HF_TOKEN is empty:
#   → PIL Lite mode: instant nail color simulation, no AI API needed
# If HF_TOKEN is set:
#   → HuggingFace SD Inpainting: AI-powered, realistic result

# ─────────────────────────────────────────────────────
# OPTIONAL: Replicate (paid, best quality)
# ─────────────────────────────────────────────────────
# REPLICATE_API_TOKEN=
